rules_version = '2';

// Chaque personne ne peut lire et écrire que son propre document,
// identifié par son uid Firebase Authentication.
// À coller dans : Console Firebase → Firestore Database → onglet "Règles".
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
